# Configuración de Ejemplo
# Copia este archivo a .env y reemplaza los valores con los tuyos

# URLs
SITE_URL=https://tudominio.com
API_BASE_URL=https://api.tudominio.com

# Mapas
LEAFLET_TILE_LAYER=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_CENTER_LAT=39.5696
MAP_CENTER_LNG=2.7236
MAP_DEFAULT_ZOOM=10

# Google Analytics (opcional)
GOOGLE_ANALYTICS_ID=

# Integración Booking (opcional)
BOOKING_AFFILIATE_ID=

# Integración TheFork (opcional)
THEFORK_API_KEY=

# Email para contacto
CONTACT_EMAIL=viajes@tudominio.com

# Modo de desarrollo
DEV_MODE=false

# Información del Viaje
TRIP_NAME=Mallorca 3 Días
TRIP_DURATION=3
TRIP_START_POINT=Calvià
TRIP_DIFFICULTY=Moderate

# Colores Personalizados (opcional)
PRIMARY_COLOR=#0066cc
SECONDARY_COLOR=#ff6b35
ACCENT_COLOR=#00d4aa

# Idioma por defecto
DEFAULT_LANGUAGE=es

# Información de Contacto
PHONE_SUPPORT=+34 XXX XXX XXX
SOCIAL_INSTAGRAM=@tuinstagram
SOCIAL_FACEBOOK=tuface
SOCIAL_TWITTER=@tutwitter

# Nota: Este archivo NO debe contener información sensible real
# Los valores aquí son solo ejemplos. Configura los valores reales en tu hosting
